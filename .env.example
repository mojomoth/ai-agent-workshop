# AI Agent Workshop - 환경변수 예시
#
# 사용법:
#   1) 이 파일을 복사해서 .env 로 만듭니다:  cp .env.example .env
#   2) 아래 값들을 실제 키로 채웁니다. (값이 비어 있어도 브라우저 OAuth 로그인은 동작)
#   3) devcontainer 사용자는 호스트 쉘에서 export 한 뒤 VS Code 를 실행해야
#      remoteEnv 로 컨테이너까지 전달됩니다.
#   4) docker compose 사용자는 자동으로 이 .env 값이 주입됩니다.

# --- Claude Code (Anthropic) ---
# 실습 계정으로 로그인(권장)하는 경우 비워둬도 됩니다.
# API 키로 바로 사용하고 싶다면 sk-ant-... 형식의 키를 입력하세요.
ANTHROPIC_API_KEY=

# --- Codex (OpenAI) ---
# 실습 계정으로 로그인(권장)하는 경우 비워둬도 됩니다.
# API 키를 쓰는 경우 sk-... 형식의 키를 입력하세요.
OPENAI_API_KEY=

# --- OpenCode (선택) ---
# OpenCode 는 여러 프로바이더를 지원합니다. 필요 시 아래 중 하나 이상을 설정하세요.
# OPENROUTER_API_KEY=
# GROQ_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
