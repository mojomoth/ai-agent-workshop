{
  "name": "AI Agent Workshop",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "remoteUser": "vscode",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/app,type=bind,consistency=cached",
  "workspaceFolder": "/workspaces/app",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-vscode-remote.remote-containers",
        "ms-azuretools.vscode-docker",
        "eamodio.gitlens"
      ]
    }
  },
  "initializeCommand": "cd ${localWorkspaceFolder} && mkdir -p .claude .codex .config/opencode .cache/opencode .local/share/opencode .local/state/opencode app",
  "mounts": [
    "source=${localWorkspaceFolder}/.codex,target=/home/vscode/.codex,type=bind,consistency=cached",
    "source=${localWorkspaceFolder}/.claude,target=/home/vscode/.claude,type=bind,consistency=cached",
    "source=${localWorkspaceFolder}/.config/opencode,target=/home/vscode/.config/opencode,type=bind,consistency=cached",
    "source=${localWorkspaceFolder}/.cache/opencode,target=/home/vscode/.cache/opencode,type=bind,consistency=cached",
    "source=${localWorkspaceFolder}/.local/share/opencode,target=/home/vscode/.local/share/opencode,type=bind,consistency=cached",
    "source=${localWorkspaceFolder}/.local/state/opencode,target=/home/vscode/.local/state/opencode,type=bind,consistency=cached"
  ],
  "postCreateCommand": "sudo chown -R vscode:vscode /home/vscode/.local /home/vscode/.config /home/vscode/.cache /home/vscode/.claude /home/vscode/.codex && git config --global --add safe.directory /workspaces/app && node -v && python3 --version && claude --version && codex --version && opencode --version",
  "containerEnv": {
    "SHELL": "/bin/bash"
  }
}
